<% layout("/layouts/boilerplate") %>
<script>
  const mapToken = "<%= process.env.Map_Token %>";
</script>
<div class="container mt-4 d-flex justify-content-center">
  <div style="max-width: 600px; width: 100%;">

    <h3 class="text-center mb-3">Listing Details :</h3>

    <img 
      src="<%= listing.image.url %>" 
      alt="listing image" 
      class="rounded mb-3 d-block mx-auto"
      style="width: 100%; max-width: 500px; height: 300px; object-fit: cover;"
    >

    <ul class="mb-3">
      <li><%= listing.title %></li>
      <li><i>Owner: <%= listing.owner ? listing.owner.username : "No owner" %></i></li>
      <li><%= listing.description %></li>
      <li>₹ <%= listing.price.toLocaleString("en-IN") %></li>
      <li><%= listing.location %></li>
      <li><%= listing.country %></li>
    </ul>

    <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
      <div class="text-center mb-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">
          Edit
        </a>
      </div>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="text-center mb-3">
        <button class="btn btn-danger">Delete</button>
      </form>
    <% } %>

    <hr>

    <!-- ⭐ REVIEW FORM -->
    <% if (currUser) { %>
      <h4 class="text-center mb-3">Leave a review</h4>

      <form action="/listings/<%= listing._id %>/reviews" method="POST">

        <fieldset class="starability-slot mb-3">
          <legend>Rating:</legend>

          <input 
            type="radio" 
            id="no-rate" 
            class="input-no-rate" 
            name="review[rating]" 
            value="0" 
            checked 
          />

          <input type="radio" id="rate1" name="review[rating]" value="1" />
          <label for="rate1">1 star</label>

          <input type="radio" id="rate2" name="review[rating]" value="2" />
          <label for="rate2">2 stars</label>

          <input type="radio" id="rate3" name="review[rating]" value="3" />
          <label for="rate3">3 stars</label>

          <input type="radio" id="rate4" name="review[rating]" value="4" />
          <label for="rate4">4 stars</label>

          <input type="radio" id="rate5" name="review[rating]" value="5" />
          <label for="rate5">5 stars</label>
        </fieldset>

        <div class="mb-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea 
            name="review[comment]" 
            id="comment" 
            class="form-control"
            required
          ></textarea>
        </div>

        <div class="text-center">
          <button class="btn btn-outline-dark">
            Submit
          </button>
        </div>

      </form>
    <% } else { %>
      <p class="text-center text-muted">Login to leave a review</p>
    <% } %>

    <hr>

    <!-- ⭐ ALL REVIEWS -->
    <h4 class="mb-3">All Reviews</h4>

    <% if (listing.reviews.length > 0) { %>
      <% for (let review of listing.reviews) { %>

        <div class="card mb-3 border border-secondary shadow-sm">
          <div class="card-body">

            <h5 class="card-title">
              <%= review.author ? review.author.username : "Anonymous User" %>
            </h5>

            <p class="card-text"><%= review.comment %></p>

            <!-- ⭐ FIXED RATING DISPLAY -->
            <p 
              class="starability-result" 
              data-rating="<%= review.rating %>"
            >
              Rated: <%= review.rating %> stars
            </p>

            <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
              <form 
                method="POST" 
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              >
                <button class="btn btn-outline-danger btn-sm">Delete</button>
              </form>
            <% } %>

          </div>
        </div>

      <% } %>
    <% } else { %>
      <p>No reviews yet.</p>
    <% } %>
    <div class="col-8 offset-3 mb-3">
      <h3>Where you'll stay</h3>
      <div id="map"></div>
    </div>

  </div>
</div>
<script src="/js/map.js"></script>