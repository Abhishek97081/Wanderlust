<style>
  .btn-search {
    background-color: #ff385c;
    color: white;
    border-radius: 20px;
    padding: 0 1rem;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 0.85rem;
    border: none;
  }

  .btn-search:hover {
    background-color: #ff385c;
    color: white;
  }

  .btn-search i {
    font-size: 0.8rem;
  }

  .search-input {
    height: 40px;
    font-size: 0.9rem;
    border-radius: 20px;
    width: 220px;
  }

  .navbar {
    padding-top: 0.4rem;
    padding-bottom: 0.4rem;
  }

  .menu-btn {
    border-radius: 50px;
    border: 1px solid #ddd;
    padding: 6px 10px;
    background-color: white;
  }

  .menu-btn i {
    font-size: 1rem;
  }
</style>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i>
    </a>

    <button 
      class="navbar-toggler" 
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#navbarNavAltMarkup"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <!-- LEFT -->
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- CENTER -->
      <div class="d-flex justify-content-center flex-grow-1">
        <form class="d-flex align-items-center" role="search" action="/listings/search" method="GET">
          <input 
            class="form-control me-2 search-input" 
            type="search" 
            name="q"
            placeholder="Search destinations"
          />
          <button class="btn btn-search" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i> Search
          </button>
        </form>
      </div>

      <!-- RIGHT -->
      <div class="navbar-nav ms-auto align-items-center">

        <a class="nav-link me-3" href="/listings/new">StayGo your home</a>

        <div class="dropdown">
          <button 
            class="btn menu-btn dropdown-toggle" 
            type="button" 
            data-bs-toggle="dropdown"
          >
            <i class="fa-solid fa-bars"></i>
          </button>

          <ul class="dropdown-menu dropdown-menu-end">

            <% if(!currUser){ %>
              <li><a class="dropdown-item" href="/signup">Signup</a></li>
              <li><a class="dropdown-item" href="/login">Login</a></li>
            <% } else { %>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            <% } %>

          </ul>
        </div>

      </div>

    </div>
  </div>
</nav>